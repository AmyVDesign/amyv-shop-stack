# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SECRET_KEY=sb_secret_...  # bypasses RLS -- server code only, never NEXT_PUBLIC

# Anthropic (photo analysis)
ANTHROPIC_API_KEY=sk-ant-api03-...
# RATE_LIMIT_DAILY=500  # default: 50 in dev / 500 in prod

# Stripe (checkout) -- NEVER use NEXT_PUBLIC for secret key
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...  # from: stripe listen --forward-to localhost:3001/api/stripe-webhook
# SHIPPING_FLAT_CENTS=1500  # default $15.00 flat shipping

# Resend (transactional email)
RESEND_API_KEY=re_...
